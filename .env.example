NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_SECRET=change-this-before-production
POSTGRES_DB=sunnypanel
POSTGRES_USER=sunnypanel
POSTGRES_PASSWORD=sunnypanel
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sunnypanel:sunnypanel@127.0.0.1:5432/sunnypanel

# Agent model configuration. The dashboard Agent first reads Payload Admin's
# Agent Settings global; if that is empty or disabled, it falls back to these.
ZAI_API_KEY=
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZAI_MODEL=glm-5.1

# Optional OpenAI-compatible aliases.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
